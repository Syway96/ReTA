# PostgreSQL 数据库连接
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=

# Chainlit 认证密钥（可自定义）
CHAINLIT_AUTH_SECRET=

# ===== LLM 配置 =====
LLM_PROVIDER=
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL_NAME=

# ===== 模型路径配置 =====
EMBEDDING_MODEL_PATH=D:/models/BAAI/bge-small-zh-v1.5
CROSS_ENCODER_MODEL_PATH=D:/models/BAAI/bge-reranker-base
